project_name        = "skillpulse"
aws_region          = "ap-south-1"
vpc_cidr            = "10.42.0.0/16"
public_subnet_cidr  = "10.42.1.0/24"
instance_type       = "t3.micro"
root_volume_size_gb = 20
enable_eks          = true
eks_cluster_version = "1.31"

eks_public_subnet_cidrs = [
  "10.42.11.0/24",
  "10.42.12.0/24"
]

eks_node_instance_types = ["t3.medium"]
eks_node_desired_size   = 2
eks_node_min_size       = 1
eks_node_max_size       = 4

# Replace with your public IP in CIDR form, for example "203.0.113.10/32".
allowed_ssh_cidr = "0.0.0.0/0"

# Use one of these SSH options:
# key_name       = "existing-aws-key-pair"
# ssh_public_key = "ssh-rsa AAAA..."

extra_tags = {
  Environment = "dev"
  Owner       = "devops-masterclass"
}
